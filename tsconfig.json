{
  "compilerOptions": {
    "lib": ["es2015"],
    "module": "commonjs",
    "target": "es6",
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "moduleResolution": "node",
    "sourceMap": true,
    "outDir": "dist",
    "strict": true,
    "declaration": true,
    "declarationMap": true
  },
  "include": ["tests/**/*"],
  "exclude": ["node_modules", "dist"]
}