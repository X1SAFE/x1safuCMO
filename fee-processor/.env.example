# X1 RPC endpoint
RPC_URL=https://rpc.testnet.x1.xyz

# Path to keypair JSON with authority over fee_collection_account
FEE_PROCESSOR_KEYPAIR=/home/jack/.config/solana/id.json

# Cron interval (seconds). Default: 900 (15 min)
INTERVAL_SECONDS=900

# Set to true to simulate without sending any transactions
DRY_RUN=false

# xDEX pool addresses (X1 Testnet)
# XNT/USDC.X pool
XDEX_POOL_XNT_USDC=

# DGN/USDC.X pool (or DGN/XNT → XNT/USDC.X two-hop)
XDEX_POOL_DGN_USDC=

# Minimum USDC.X to trigger a distribution run (avoid dust txs)
MIN_DISTRIBUTE_USDC=0.01

# Slippage tolerance for swaps (basis points, default 100 = 1%)
SWAP_SLIPPAGE_BPS=100

# Alert webhook (optional — posts on distribution)
# ALERT_WEBHOOK_URL=https://...
